@model Invoice_Management.Models.ViewModels.CreateProductViewModel

@{
    ViewBag.Title = "Create Product";
}

<h2>Create Product</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(m => m.Name)
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Name)
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.CostPerItem)
        @Html.TextBoxFor(m => m.CostPerItem, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.CostPerItem)
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.QuantityInStock)
        @Html.TextBoxFor(m => m.QuantityInStock, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.QuantityInStock)
    </div>

    <button type="submit" class="btn btn-success">Save</button>
}