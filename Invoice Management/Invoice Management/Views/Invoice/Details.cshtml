@model Invoice_Management.Models.ViewModels.InvoiceModel.InvoiceDetailsViewModel

<h2>Invoice Details</h2>

<a href="@Url.Action("Create", "Invoice")" class="btn btn-primary">
    + Create New Invoice
</a>

<br />
<br />

<p><strong>Total:</strong> @Model.Total</p>

@if (TempData["Error"] != null)
{
    <div style="color:red">@TempData["Error"]</div>
}

<hr />

<h3>Items</h3>

<table class="table table-striped table-bordered">
    <tr>
        <th>Product</th>
        <th>Quantity</th>
        <th>Unit Price</th>
        <th>Total</th>
        <th></th>
    </tr>

    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.ProductName</td>
            <td>@item.Quantity</td>
            <td>@item.UnitPrice</td>
            <td>@item.LineTotal</td>
            <td>
                @using (Html.BeginForm("RemoveItem", "Invoice"))
                {
                    @Html.Hidden("invoiceId", Model.Id)
                    @Html.Hidden("productId", item.ProductId)

                    <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                }
            </td>
        </tr>
    }
</table>

<hr />

<h3>Add Item</h3>

@using (Html.BeginForm("AddItem", "Invoice"))
{
    @Html.Hidden("invoiceId", Model.Id)

    <div class="row">
        <div class="col-md-4">
            <label>Product</label>
            @Html.DropDownList("productId", Model.Products, "-- Select Product --", new { @class = "form-control" })
        </div>

        <div class="col-md-3">
            <label>Quantity</label>
            <input type="number" name="quantity" class="form-control" required />
        </div>

        <div class="col-md-3" style="margin-top:25px;">
            <button type="submit" class="btn btn-primary">
                Add Item
            </button>
        </div>
    </div>
}

<hr />

@using (Html.BeginForm("Save", "Invoice"))
{
    @Html.Hidden("invoiceId", Model.Id)
    <button type="submit" class="btn btn-success">Finalize Invoice</button>
}