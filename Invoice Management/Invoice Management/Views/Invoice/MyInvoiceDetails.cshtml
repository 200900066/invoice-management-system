@model Invoice_Management.Models.InvoiceDataModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .invoice-container {
        background: #fff;
        padding: 30px;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        margin: 30px auto;
        max-width: 1000px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

        table th, table td {
            border: 1px solid #ddd;
            padding: 10px;
        }

        table th {
            background-color: #007bff;
            color: white;
        }

    .product-row {
        display: flex;
        gap: 10px;
        align-items: center;
        margin-top: 20px;
    }

        .product-row select,
        .product-row input {
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            height: 38px;
        }

        .product-row input {
            width: 80px;
            text-align: center;
        }

    .add-btn {
        background-color: #28a745;
        color: white;
        border: none;
        padding: 8px 15px;
        border-radius: 4px;
        cursor: pointer;
        height: 38px;
    }

    .remove-btn {
        background: #dc3545;
        color: white;
        border: none;
        padding: 5px 10px;
        border-radius: 4px;
    }

    .total {
        margin-top: 20px;
        text-align: right;
        font-size: 20px;
        font-weight: bold;
    }
</style>

<div class="invoice-container">

    <h1>Create Invoice</h1>

    @Html.ActionLink("Back to Invoices", "Index", "Invoice", null, new { @class = "btn btn-primary" })

    <input type="hidden" id="invoiceId" value="@Model.Invoice.Id" />

    <div>
        <strong>Invoice ID:</strong> @Model.Invoice.Id <br />
        <strong>Created Date:</strong> @Model.Invoice.CreatedDate.ToString("yyyy-MM-dd") <br />
        <strong>Created By:</strong> @Model.Invoice.CreatedByUserName
    </div>

    <hr />

    <!-- ADD ITEM -->
    @if (!User.IsInRole("Manager"))
    {
        <div class="product-row">
            <select id="productSelect">
                <option value="">-- Select Product --</option>
                @foreach (var p in Model.Products)
                {
                    <option value="@p.Id"
                            data-name="@p.Name"
                            data-price="@p.CostPerItem">
                        @p.Name - @p.CostPerItem
                    </option>
                }
            </select>

            <input type="number"
                   id="quantity"
                   value="1"
                   min="1"
                   oninput="this.value = Math.max(1, this.value)" />

            <button type="button" class="add-btn" onclick="addItem()">Add</button>
        </div>
    }

    <!-- TABLE -->
    <table>
        <thead>
            <tr>
                <th>Product</th>
                <th>Qty</th>
                <th>Price</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody id="invoiceItemsBody"></tbody>
    </table>

    <div class="total">
        Grand Total: <span id="grandTotal">0.00</span>
    </div>

    <form id="finalizeForm" method="post" action="/Invoice/Finalize"></form>

    <button type="button" class="btn btn-primary" onclick="finalize()">Finalize Invoice</button>

</div>

<script>
    let invoiceItems = [];
    const invoiceId = document.getElementById("invoiceId").value;

    function addItem() {
        const select = document.getElementById("productSelect");
        const qtyInput = document.getElementById("quantity");

        const quantity = parseInt(qtyInput.value);
        const selectedOption = select.options[select.selectedIndex];

        if (!selectedOption.value) {
            alert("Select a product");
            return;
        }

        if (!quantity || quantity <= 0) {
            alert("Quantity must be greater than 0");
            return;
        }

        const productId = selectedOption.value;

        const existing = invoiceItems.find(i => i.productId == productId);

        if (existing) {
            existing.quantity += quantity;
        } else {
            invoiceItems.push({
                productId: productId,
                invoiceId: invoiceId,
                name: selectedOption.getAttribute("data-name"),
                unitPrice: parseFloat(selectedOption.getAttribute("data-price")),
                quantity: quantity
            });
        }

        qtyInput.value = 1;
        select.selectedIndex = 0;

        renderTable();
    }

    function renderTable() {
        const tbody = document.getElementById("invoiceItemsBody");
        tbody.innerHTML = "";

        let total = 0;

        invoiceItems.forEach((item, index) => {
            const rowTotal = item.quantity * item.unitPrice;
            total += rowTotal;

            tbody.innerHTML += `
                <tr>
                    <td>${item.name}</td>

                    <td>
                        <input type="number"
                               value="${item.quantity}"
                               min="1"
                               oninput="this.value = Math.max(1, this.value)"
                               onchange="updateQty(${index}, this.value)" />
                    </td>

                    <td>${item.unitPrice.toFixed(2)}</td>
                    <td>${rowTotal.toFixed(2)}</td>

                    <td>
                        <button type="button" class="remove-btn"
                                onclick="removeItem(${index})">
                            Remove
                        </button>
                    </td>
                </tr>
            `;
        });

        document.getElementById("grandTotal").innerText = total.toFixed(2);
    }

    function updateQty(index, value) {
        const qty = parseInt(value);

        if (!qty || qty <= 0) {
            alert("Invalid quantity");
            renderTable();
            return;
        }

        invoiceItems[index].quantity = qty;
        renderTable();
    }

    function removeItem(index) {
        invoiceItems.splice(index, 1);
        renderTable();
    }

    function finalize() {
        if (invoiceItems.length === 0) {
            alert("No items added");
            return;
        }

        const form = document.getElementById("finalizeForm");
        form.innerHTML = "";

        invoiceItems.forEach((item, index) => {
            form.innerHTML += `
                <input type="hidden" name="vm[${index}].InvoiceId" value="${item.invoiceId}" />
                <input type="hidden" name="vm[${index}].ProductId" value="${item.productId}" />
                <input type="hidden" name="vm[${index}].Quantity" value="${item.quantity}" />
                <input type="hidden" name="vm[${index}].UnitPrice" value="${item.unitPrice}" />
            `;
        });

        form.submit();
    }

    renderTable();
</script>
