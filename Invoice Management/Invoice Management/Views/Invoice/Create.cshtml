@model Invoice_Management.Models.ViewModels.InvoiceModel.InvoiceCreateViewModel

<h2>Invoice Details</h2>

<a href="@Url.Action("Create", "Invoice")" class="btn btn-primary">
    + Create New Invoice
</a>

<br />
<br />

<h3>Total: <span id="total">0.00</span></h3>

@if (TempData["Error"] != null)
{
    <div style="color:red">@TempData["Error"]</div>
}

<hr />

<h3>Items</h3>

