@{
    ViewBag.Title = "Invoices";
}

<a href="@Url.Action("Create", "Invoice")" class="btn btn-primary">
    + Create New Invoice
</a>

<h2>My Invoices</h2>

<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>User</th>
            <th>Total</th>
            <th></th> 
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                <td>@item.CreatedByUserName</td>
                <td>@item.Total.ToString("0.00")</td>

                <td>
                    @Html.ActionLink(
                        "Details",
                        "Details",
                        "Invoice",
                        new { id = item.Id }, 
                        new { @class = "btn btn-warning btn-sm" }
                    )
                </td>
            </tr>
        }
    </tbody>
</table>