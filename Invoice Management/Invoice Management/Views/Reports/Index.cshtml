@model InvoiceManagement.Application.Services.ReportData

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
    .report-body {
        padding: 30px;
        background: #f8fafc;
    }

    .card {
        padding: 20px;
        border-radius: 10px;
        background: white;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(200px,1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .table-container {
        background: white;
        border-radius: 10px;
        margin-bottom: 30px;
    }

    .table-header {
        padding: 15px;
        border-bottom: 1px solid #eee;
    }

    .low-stock {
        background: #ffe5e5;
        color: #b91c1c;
    }
</style>

<div class="report-body">
    <div class="container">

        <h2 class="mb-4">IMS Reporting</h2>

        <!-- CARDS -->
        <div class="stats-grid">
            <div class="card">
                <h6>Total Products</h6>
                <h3>@Model.TotalProducts</h3>
            </div>
            <div class="card">
                <h6>Total Stock</h6>
                <h3>@Model.TotalStock</h3>
            </div>
            <div class="card">
                <h6>Total Sold</h6>
                <h3>@Model.TotalProductsSold</h3>
            </div>
        </div>
        <div class="accordion" id="reportAccordion">

            <!-- ITEMS SOLD -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#soldCollapse">
                        <i class="bi bi-bar-chart me-2"></i> Items Sold Per Product
                    </button>
                </h2>

                <div id="soldCollapse" class="accordion-collapse collapse show" data-bs-parent="#reportAccordion">
                    <div class="accordion-body">

                        <div class="d-flex justify-content-end mb-2">
                            <div class="input-group w-25">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input id="searchSold" class="form-control" placeholder="Search product..." />
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped" id="soldTable">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Product</th>
                                        <th>Sold</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.ItemsSoldPerProduct)
                                    {
                                        <tr>
                                            <td>#@item.ProductId</td>
                                            <td class="product-name">@item.ProductName</td>
                                            <td>@item.TotalItemsSold</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div id="soldPagination"></div>
                    </div>
                </div>
            </div>

            <!-- STOCK VS SOLD -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#stockCollapse">
                        <i class="bi bi-box-seam me-2"></i> Stock vs Sold
                    </button>
                </h2>

                <div id="stockCollapse" class="accordion-collapse collapse" data-bs-parent="#reportAccordion">
                    <div class="accordion-body">

                        <div class="d-flex justify-content-end mb-2">
                            <div class="input-group w-25">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input id="searchStock" class="form-control" placeholder="Search product..." />
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped" id="stockTable">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Product</th>
                                        <th>Sold</th>
                                        <th>Stock</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.StockVsSoldPerProduct)
                                    {
                                        var isLow = item.QuantityInStock <= 5;

                                        <tr class="@(isLow ? "low-stock" : "")">
                                            <td>#@item.ProductId</td>
                                            <td class="product-name">
                                                @item.ProductName
                                                @if (isLow)
                                                {
                                                    <span class="text-danger">(Low)</span>
                                                }
                                            </td>
                                            <td>@item.TotalItemsSold</td>
                                            <td>@item.QuantityInStock</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div id="stockPagination"></div>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>

<script>
    function setupTable(tableId, searchId, paginationId) {
        const table = document.getElementById(tableId);
        const rows = Array.from(table.querySelectorAll("tbody tr"));
        const searchInput = document.getElementById(searchId);
        const pagination = document.getElementById(paginationId);

        let filteredRows = [...rows];
        let currentPage = 1;
        const pageSize = 10;

        function render() {
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;

            rows.forEach(r => r.style.display = "none");
            filteredRows.slice(start, end).forEach(r => r.style.display = "");

            renderPagination();
        }

        function renderPagination() {
            pagination.innerHTML = "";
            const totalPages = Math.ceil(filteredRows.length / pageSize);

            for (let i = 1; i <= totalPages; i++) {
                let btn = document.createElement("button");
                btn.innerText = i;
                btn.className = "btn btn-sm btn-outline-primary me-1";

                if (i === currentPage) btn.classList.add("active");

                btn.onclick = () => {
                    currentPage = i;
                    render();
                };

                pagination.appendChild(btn);
            }
        }

        searchInput.addEventListener("keyup", function () {
            const keyword = this.value.toLowerCase();

            filteredRows = rows.filter(r =>
                r.querySelector(".product-name").innerText.toLowerCase().includes(keyword)
            );

            currentPage = 1;
            render();
        });

        render();
    }

    setupTable("soldTable", "searchSold", "soldPagination");
    setupTable("stockTable", "searchStock", "stockPagination");
</script>